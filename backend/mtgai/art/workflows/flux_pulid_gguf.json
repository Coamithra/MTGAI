{
  "1": {
    "class_type": "UnetLoaderGGUF",
    "_meta": { "title": "Load Flux Q5_K_S" },
    "inputs": {
      "unet_name": "flux1-dev-Q5_K_S.gguf"
    }
  },
  "2": {
    "class_type": "DualCLIPLoaderGGUF",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5-v1_1-xxl-encoder-Q8_0.gguf",
      "type": "flux"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    }
  },
  "20": {
    "class_type": "PulidFluxModelLoader",
    "_meta": { "title": "Load PuLID Model" },
    "inputs": {
      "pulid_file": "pulid_flux_v0.9.1.safetensors"
    }
  },
  "21": {
    "class_type": "PulidFluxInsightFaceLoader",
    "_meta": { "title": "Load InsightFace" },
    "inputs": {
      "provider": "CUDA"
    }
  },
  "22": {
    "class_type": "PulidFluxEvaClipLoader",
    "_meta": { "title": "Load EVA-CLIP" },
    "inputs": {}
  },
  "11": {
    "class_type": "LoadImage",
    "_meta": { "title": "Load Reference Portrait" },
    "inputs": {
      "image": "REFERENCE_IMAGE_PLACEHOLDER"
    }
  },
  "23": {
    "class_type": "ApplyPulidFlux",
    "_meta": { "title": "Apply PuLID Face Identity" },
    "inputs": {
      "model": ["1", 0],
      "pulid_flux": ["20", 0],
      "eva_clip": ["22", 0],
      "face_analysis": ["21", 0],
      "image": ["11", 0],
      "weight": 0.8,
      "start_at": 0.0,
      "end_at": 1.0
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive Prompt" },
    "inputs": {
      "text": "PROMPT_PLACEHOLDER",
      "clip": ["2", 0]
    }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt (empty for Flux)" },
    "inputs": {
      "text": "",
      "clip": ["2", 0]
    }
  },
  "6": {
    "class_type": "FluxGuidance",
    "inputs": {
      "conditioning": ["4", 0],
      "guidance": 4.0
    }
  },
  "7": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": 1024,
      "height": 768,
      "batch_size": 1
    }
  },
  "8": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["23", 0],
      "seed": 42,
      "steps": 30,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "positive": ["6", 0],
      "negative": ["5", 0],
      "latent_image": ["7", 0],
      "denoise": 1.0
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["8", 0],
      "vae": ["3", 0]
    }
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["9", 0],
      "filename_prefix": "mtgai_pulid"
    }
  }
}
